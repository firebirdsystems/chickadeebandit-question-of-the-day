{
  "id": "question-of-the-day",
  "name": "Question of the Day",
  "version": "1.0.0",
  "description": "One conversation-starter a day. Everyone answers in secret; the answers unlock when the whole household has weighed in — or automatically at the end of the day.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "games",
  "tags": ["family", "questions", "conversation", "daily", "game"],
  "icon": "💬",
  "data_access": {
    "reads": ["family.members"],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "storage": "db",
  "db_plaintext_columns": ["question_date"],
  "row_policies": {
    "rounds": {
      "kind": "owner_or_visibility",
      "member_column": "created_by",
      "visibility_column": "visibility",
      "everyone_values": ["everyone"],
      "write_visibility_scoped": true
    },
    "answers": {
      "kind": "sealed_until",
      "fk_column": "round_id",
      "parent_table": "rounds",
      "writer_column": "member_id",
      "parent_status_column": "status",
      "visible_parent_status_values": ["closed"],
      "visible_after_parent_column": "reveal_at",
      "max_per_member": {
        "member_column": "member_id",
        "scope_columns": ["round_id"],
        "limit": 1
      },
      "frozen_when": {
        "status_column": "status",
        "locked_values": ["closed"]
      }
    },
    "marks": {
      "kind": "inherit_visibility",
      "fk_column": "round_id",
      "parent_table": "rounds",
      "writer_column": "member_id",
      "max_per_member": {
        "member_column": "member_id",
        "scope_columns": ["round_id"],
        "limit": 1
      }
    }
  },
  "nav": { "label": "Question" },
  "resource_limits": {
    "max_db_bytes": 52428800
  }
}
